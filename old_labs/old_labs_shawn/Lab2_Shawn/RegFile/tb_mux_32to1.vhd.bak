library IEEE;
use IEEE.std_logic_1164.all;

entity tb_mux_32to1 is
  
end tb_mux_32to1;

architecture behavioral of tb_mux_32to1 is
  
  -- Calculate the clock period as twice the half-period
 -- constant cCLK_PER  : time := gCLK_HPER * 2;


  component mux_32to1
    port(select_lines           : in std_logic_vector(4 downto 0);  
         data_inputs        	: in std_logic_vector(31 downto 0);
         output_data		: out std_logic		
         );  
  end component;

  -- Temporary signals to connect to the dff component.
  signal s_select_lines		: std_logic_vector(4 downto 0)  := "00000";  
  signal s_data_inputs		: std_logic_vector(31 downto 0) := "00000000000000000000000000000000";
  signal s_output_data		: std_logic; 
begin

  DUT: mux_32to1 
  port map(select_lines => s_select_lines, 
           data_inputs  => s_data_inputs,
	   output_data  => s_output_data);

  -- This process sets the clock value (low for gCLK_HPER, then high
  -- for gCLK_HPER). Absent a "wait" command, processes restart 
  -- at the beginning once they have reached the final statement.
--  P_CLK: process
--  begin
 --   s_CLK <= '0';
 --   wait for gCLK_HPER;
 --   s_CLK <= '1';
--    wait for gCLK_HPER;
--  end process;
  
  -- Testbench process  
  P_TB: process
  begin
    -- Reset the FF
  --  s_RST <= '1';
  --  s_WE  <= '0';
 --   s_D   <= (0 => '0', others => '0');
   -- wait for 100 ns;
    s_data_inputs <= x"F0F0F0F2"; 
    -- Access 'RISC-V temp register 1...t1 = x5'
    s_select_lines   <= "00101";
    wait for 100 ns; 
    -- Expect output_data to be 1 


    -- Access 'RISC-V saved register 1...s0 = x8'
    s_select_lines   <= "01000";
    wait for 100 ns; 
    -- Expect output data to be 0

    -- Access 'RISC-V argument register 1...t0 = x10'
    s_select_lines   <= "01010";
    wait for 100 ns; 
    -- Expect output data to be 0

    -- Access 'RISC-V return address register...ra = x1'
    s_input_address   <= "00001";
    wait for 100 ns; 
    -- Expect output data to be 1

    wait;
  end process;
  
end behavioral;